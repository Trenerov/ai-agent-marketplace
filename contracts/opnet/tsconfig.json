{
  "compilerOptions": {
    "module": "esnext",
    "declaration": true,
    "target": "esnext",
    "noImplicitAny": true,
    "removeComments": true,
    "preserveConstEnums": true,
    "resolveJsonModule": true,
    "skipLibCheck": false,
    "sourceMap": false,
    "moduleDetection": "force",
    "experimentalDecorators": true,
    "lib": ["es6"],
    "strict": true,
    "moduleResolution": "node",
    "allowJs": false,
    "incremental": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "build"
  },
  "include": ["./tests/*.ts", "./tests/**/*.ts"]
}
